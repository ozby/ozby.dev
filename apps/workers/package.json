{
  "name": "@ozby-dev/workers",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ozby/cloudflare": "catalog:"
  },
  "scripts": {
    "typegen": "wp exec wrangler types",
    "prebuild": "wp exec wrangler types && vp run --filter @ozby-dev/client build",
    "dev": "wp exec wrangler dev --config wrangler.jsonc",
    "build": "wp exec wrangler deploy --config wrangler.jsonc --dry-run",
    "test": "wp test --file vitest.config.ts",
    "check-types": "wp typecheck",
    "lint": "wp lint"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.100.0"
  }
}