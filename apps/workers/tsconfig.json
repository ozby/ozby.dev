{
  "extends": "@webpresso/agent-kit/tsconfig/cloudflare.json",
  "compilerOptions": {
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "./worker-configuration.d.ts",
      "node",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "erasableSyntaxOnly": false,
    "paths": {
      "#*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "wrangler.jsonc"
  ]
}
