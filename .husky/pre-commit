#!/usr/bin/env sh
set -eu
WP_SKIP_UPDATE_CHECK=1 wp audit secrets-policy
WP_SKIP_UPDATE_CHECK=1 wp audit absolute-path-policy --root .
WP_SKIP_UPDATE_CHECK=1 wp audit secrets-config
WP_SKIP_UPDATE_CHECK=1 wp audit secret-provider-quarantine
WP_SKIP_UPDATE_CHECK=1 wp audit no-dev-vars
# webpresso audit hooks (staged mode — fast)
STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
FORMAT_FILES="$(printf '%s\n' "$STAGED" | grep -E '\.(ts|tsx|js|jsx|cjs|mjs|json|ya?ml|sh|tmpl|md|mdx)$' || true)"
if [ -n "$FORMAT_FILES" ]; then
  wp format || exit 1
  printf '%s\n' "$FORMAT_FILES" | while IFS= read -r file; do
    [ -n "$file" ] || continue
    git add -- "$file" || exit 1
  done
  STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
fi
if printf '%s\n' "$STAGED" | grep -Eq '\.(ts|tsx|js|jsx|cjs|mjs|json|ya?ml|sh|tmpl)$|(^|/)\.env|\.dev\.vars$'; then
  wp audit no-dev-vars
  wp audit absolute-path-policy --root .
  wp audit secret-provider-quarantine
fi
# webpresso audit hooks (affected mode — fast)
wp format --affected || exit 1
if ! git diff --cached --quiet --diff-filter=ACMR; then
  git diff -z --cached --name-only --diff-filter=ACMR |
    git add --pathspec-from-file=- --pathspec-file-nul || exit 1
fi
wp audit guardrails --affected
