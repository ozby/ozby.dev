{
  "name": "ozby-dev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "vp run --filter @ozby-dev/client build && vp run --filter @ozby-dev/workers dev",
    "build": "vp run --filter @ozby-dev/client build && vp run --filter @ozby-dev/workers build",
    "typecheck": "vp run --filter @ozby-dev/client check-types && vp run --filter @ozby-dev/workers check-types && vp run --filter @ozby-dev/infra check-types && wp typecheck",
    "test": "vp run --filter @ozby-dev/client test && vp run --filter @ozby-dev/workers test && vp run --filter @ozby-dev/infra test && wp test --file test/ci-governance-contract.test.ts",
    "lint": "wp lint",
    "qa": "wp lint && pnpm run typecheck && pnpm run test",
    "prepare": "husky",
    "postinstall": "test -n \"$CI\" || wp setup && (test -n \"$CI\" || bun infra/src/deploy/sync-webpresso-config.ts)",
    "setup:agent": "wp setup",
    "setup:secrets": "bun infra/src/deploy/sync-webpresso-config.ts --force",
    "verify:secrets": "wp audit no-dev-vars && wp audit secret-provider-quarantine",
    "verify:deploy-contract": "wp audit cloudflare-deploy-contract",
    "test:mutation": "wp test --mutation",
    "blueprints:check": "wp audit blueprint-lifecycle",
    "deploy:dry-run": "wp deploy --lane prd --dry-run",
    "deploy:preview": "wp deploy --lane preview_main",
    "deploy:production": "wp deploy --lane prd",
    "deploy:production:wrangler": "bun infra/src/deploy/deploy-production.ts",
    "verify:paths": "wp audit absolute-path-policy --root .",
    "audit:secret-provider-quarantine": "WP_SKIP_UPDATE_CHECK=1 wp audit secret-provider-quarantine",
    "mutation": "wp test --mutation",
    "e2e": "wp e2e --config playwright.config.ts",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version": "changeset version && bun scripts/sync-release-metadata-version.ts",
    "release:publish": "bun scripts/release-publish.ts"
  },
  "files": [
    "LICENSE",
    "THIRD-PARTY-NOTICES.md",
    "catalog/agent/skills/"
  ],
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "latest",
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.4",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/typescript-checker": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@types/node": "catalog:",
    "@webpresso/agent-config": "catalog:",
    "@webpresso/agent-kit": "catalog:",
    "husky": "^9.1.7",
    "secretlint": "^9.3.4",
    "typescript": "catalog:",
    "vite-plus": "^0.1.24",
    "vitest": "catalog:",
    "@changesets/cli": "^2.29.5"
  },
  "engines": {
    "node": ">=24"
  },
  "version": "0.1.0"
}
