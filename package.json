{
  "name": "ozby-dev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "wp exec vite build",
    "typecheck": "wp typecheck",
    "test": "wp test --file src/projects.test.ts --file src/worker.test.ts",
    "lint": "wp lint",
    "qa": "wp lint && wp typecheck && pnpm run test",
    "setup:secrets": "bun scripts/sync-webpresso-config.ts --force",
    "verify:deploy-contract": "wp audit cloudflare-deploy-contract",
    "deploy:dry-run": "bun scripts/deploy-production.ts --dry-run --skip-smoke",
    "deploy:production": "bun scripts/deploy-production.ts",
    "deploy:production:wrangler": "bun scripts/deploy-production.ts"
  },
  "dependencies": {
    "@webpresso/agent-kit": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.22.0"
  }
}
