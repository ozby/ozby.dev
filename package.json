{
  "name": "ozby-dev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "wp exec vite build",
    "typecheck": "wp typecheck",
    "test": "wp test --file src/projects.test.ts --file src/worker.test.ts --file src/deploy-contract.test.ts",
    "lint": "wp lint",
    "qa": "wp lint && wp typecheck && wp test --file src/projects.test.ts --file src/worker.test.ts --file src/deploy-contract.test.ts",
    "postinstall": "test -n \"$CI\" || bun scripts/sync-webpresso-config.ts",
    "setup:secrets": "bun scripts/sync-webpresso-config.ts --force",
    "verify:secrets": "bun scripts/verify-secrets-policy.ts && bun scripts/sync-webpresso-config.ts --check-only",
    "verify:deploy-contract": "wp audit cloudflare-deploy-contract",
    "deploy:dry-run": "wp deploy --lane prd --dry-run",
    "deploy:preview": "wp deploy --lane preview_main",
    "deploy:production": "wp deploy --lane prd",
    "deploy:production:wrangler": "bun scripts/deploy-production.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@webpresso/agent-kit": "latest",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.22",
    "vitest": "^4.1.7",
    "wrangler": "^4.22.0"
  }
}
